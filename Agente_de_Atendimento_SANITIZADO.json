    {
      "parameters": {
        "jsCode": "const msg = $json.mensagem || '';\nconst instancia = $json.instancia || 'orizon';\n\nconst telefone = ($json.numero || '')\n  .split('@')[0]\n  .replace(/\\D/g, '');\n\nconst email =\n  msg.match(/[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}/)?.[0] ||\n  'Não informado';\n\nlet nome = $json.nome || 'Não informado';\n\nconst nomeMatch = msg.match(\n  /(?:meu nome é|me chamo|sou o|sou a|aqui é|aqui é o|aqui é a|olá,\\s*me chamo|ola,\\s*me chamo|olá,\\s*sou|ola,\\s*sou)\\s+([A-Za-zÀ-ÿ\\s]{2,80})/i\n);\n\nif (nomeMatch?.[1]) {\n  nome = nomeMatch[1]\n    .trim()\n    .replace(/[.,!?].*$/, '')\n    .trim();\n}\n\nconst texto = msg.toLowerCase();\n\nlet categoria = 'Comercial';\n\nif (\n  texto.includes('financeiro') ||\n  texto.includes('boleto') ||\n  texto.includes('pagamento') ||\n  texto.includes('pagar') ||\n  texto.includes('nota fiscal') ||\n  texto.includes('nf') ||\n  texto.includes('cobrança') ||\n  texto.includes('cobranca') ||\n  texto.includes('fatura') ||\n  texto.includes('segunda via') ||\n  texto.includes('pix') ||\n  texto.includes('reembolso') ||\n  texto.includes('valor cobrado')\n) {\n  categoria = 'Financeiro';\n} else if (\n  texto.includes('suporte') ||\n  texto.includes('erro') ||\n  texto.includes('problema') ||\n  texto.includes('lentidão') ||\n  texto.includes('lentidao') ||\n  texto.includes('falha') ||\n  texto.includes('bug') ||\n  texto.includes('sistema') ||\n  texto.includes('n8n') ||\n  texto.includes('não funciona') ||\n  texto.includes('nao funciona') ||\n  texto.includes('não consigo') ||\n  texto.includes('nao consigo') ||\n  texto.includes('travando') ||\n  texto.includes('dúvida técnica') ||\n  texto.includes('duvida tecnica') ||\n  texto.includes('instabilidade') ||\n  texto.includes('integração com erro') ||\n  texto.includes('integracao com erro')\n) {\n  categoria = 'Suporte';\n} else if (\n  texto.includes('comercial') ||\n  texto.includes('proposta') ||\n  texto.includes('orçamento') ||\n  texto.includes('orcamento') ||\n  texto.includes('serviços') ||\n  texto.includes('servicos') ||\n  texto.includes('contratar') ||\n  texto.includes('preço') ||\n  texto.includes('preco') ||\n  texto.includes('valores') ||\n  texto.includes('diagnóstico') ||\n  texto.includes('diagnostico') ||\n  texto.includes('consultoria') ||\n  texto.includes('automação') ||\n  texto.includes('automacao') ||\n  texto.includes('inteligência artificial') ||\n  texto.includes('inteligencia artificial') ||\n  texto.includes('ia')\n) {\n  categoria = 'Comercial';\n}\n\nconst assunto = msg || 'Não informado';\n\nreturn [\n  {\n    json: {\n      ...$json,\n      nome,\n      telefone,\n      email,\n      assunto,\n      categoria,\n      instancia,\n\n      nomeExtraido: nome,\n      telefoneLimpo: telefone,\n      emailExtraido: email,\n      categoriaDetectada: categoria\n    }\n  }\n];"
      },
