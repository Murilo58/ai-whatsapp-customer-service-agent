    {
      "parameters": {
        "jsCode": "const dadosEntrada = $('Code in JavaScript').first().json;\nconst dadosAgente = $('AI Agent').first().json;\n\nconst nome = dadosEntrada.nome || '';\nconst telefone = dadosEntrada.telefone || '';\nconst email = dadosEntrada.email || '';\nconst assunto = dadosEntrada.assunto || '';\nconst categoria = dadosEntrada.categoria || '';\n\nconst resposta_whatsapp = dadosAgente.output || '';\n\nconst cadastro_finalizado =\n  nome !== 'Não informado' &&\n  telefone !== '' &&\n  assunto !== 'Não informado' &&\n  categoria !== '';\n\nreturn [\n  {\n    json: {\n      ...dadosEntrada,\n      resposta_whatsapp,\n      cadastro_finalizado\n    }\n  }\n];"
      },
